# ===== Google Analytics 4 (GA4) =====
# Measurement ID from your GA4 property
# Get from: Google Analytics > Admin > Property > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===== Google AdSense =====
# Your AdSense Publisher ID
# Get from: AdSense > Settings > Account > Publisher ID
NEXT_PUBLIC_ADSENSE_ID=ca-pub-xxxxxxxxxxxxxxxx

# ===== Anthropic API =====
# API Key for AI explanations ("Preview by Claude" feature)
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX
