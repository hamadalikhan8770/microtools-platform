{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "env": [
    {
      "key": "NEXT_PUBLIC_GA_ID",
      "value": "@NEXT_PUBLIC_GA_ID"
    }
  ],
  "envSecrets": [
    "NEXT_PUBLIC_GA_ID"
  ],
  "git": {
    "deploymentEnabled": {
      "main": true,
      "master": true,
      "develop": false
    }
  }
}
